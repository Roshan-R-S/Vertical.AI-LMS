generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  TEAM_LEAD
  BDE
}

enum LeadStatus {
  active
  won
  lost
}

enum LeadPriority {
  Low
  Medium
  High
}

enum DispositionType {
  positive
  neutral
  negative
}

enum InteractionType {
  call
  email
  whatsapp
  meeting
  note
}

enum InteractionDirection {
  inbound
  outbound
}

enum Sentiment {
  positive
  neutral
  negative
}

enum TaskStatus {
  pending
  overdue
  completed
}

enum ClientStatus {
  active
  renewal_due
  churned
}

enum InvoiceStatus {
  paid
  unpaid
  partial
}

enum NotificationType {
  info
  success
  warning
  danger
}

// ─────────────────────────────────────────
// TEAMS
// ─────────────────────────────────────────

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())

  @@map("teams")
}

// ─────────────────────────────────────────
// USERS
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role      @default(BDE)
  avatar        String?
  phone         String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  teamId        String?
  team          Team?     @relation(fields: [teamId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedLeads  Lead[]        @relation("AssignedLeads")
  createdLeads   Lead[]        @relation("CreatedLeads")
  managedClients Client[]      @relation("AccountManager")
  interactions   Interaction[]
  assignedTasks  Task[]        @relation("AssignedTasks")
  createdTasks   Task[]        @relation("CreatedTasks")
  attachments    Attachment[]
  auditLogs      AuditLog[]
  notifications  Notification[]

  @@map("users")
}

// ─────────────────────────────────────────
// MILESTONES & DISPOSITIONS (Pipeline Config)
// ─────────────────────────────────────────

model Milestone {
  id           String        @id @default(cuid())
  name         String        @unique
  order        Int
  color        String
  dispositions Disposition[]
  leads        Lead[]
  createdAt    DateTime      @default(now())

  @@map("milestones")
}

model Disposition {
  id          String          @id @default(cuid())
  milestoneId String
  milestone   Milestone       @relation(fields: [milestoneId], references: [id])
  name        String
  description String?
  type        DispositionType @default(neutral)
  isActive    Boolean         @default(true)
  isDefault   Boolean         @default(false)
  leads       Lead[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("dispositions")
}

// ─────────────────────────────────────────
// LEADS
// ─────────────────────────────────────────

model Lead {
  id            String       @id @default(cuid())
  companyName   String
  contactName   String
  email         String?
  phone         String
  source        String?
  industry      String?
  tags          String[]
  milestoneId   String?
  milestone     Milestone?   @relation(fields: [milestoneId], references: [id])
  dispositionId String?
  disposition   Disposition? @relation(fields: [dispositionId], references: [id])
  status        LeadStatus   @default(active)
  priority      LeadPriority @default(Medium)
  score         Int          @default(0)
  value         Float        @default(0)
  probability   Int          @default(0)
  expectedClose DateTime?
  notes         String?
  linkedIn      String?
  assignedToId  String
  assignedTo    User         @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdById   String
  createdBy     User         @relation("CreatedLeads", fields: [createdById], references: [id])
  nextFollowUp  DateTime?
  lastFollowUp  DateTime?
  interactions  Interaction[]
  tasks         Task[]
  attachments   Attachment[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([companyName])
  @@index([assignedToId])
  @@index([milestoneId])
  @@map("leads")
}

// ─────────────────────────────────────────
// INTERACTIONS
// ─────────────────────────────────────────

model Interaction {
  id             String                @id @default(cuid())
  leadId         String?
  lead           Lead?                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type           InteractionType
  direction      InteractionDirection?
  subject        String?
  summary        String
  duration       String?
  sentiment      Sentiment             @default(neutral)
  hasTranscript  Boolean               @default(false)
  hasRecording   Boolean               @default(false)
  performedById  String
  performedBy    User                  @relation(fields: [performedById], references: [id])
  createdAt      DateTime              @default(now())
  deletedAt      DateTime?

  @@index([leadId])
  @@map("interactions")
}

// ─────────────────────────────────────────
// TASKS & FOLLOW-UPS
// ─────────────────────────────────────────

model Task {
  id           String     @id @default(cuid())
  title        String
  leadId       String?
  lead         Lead?      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedToId String
  assignedTo   User       @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User       @relation("CreatedTasks", fields: [createdById], references: [id])
  dueDate      DateTime
  status       TaskStatus @default(pending)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@index([assignedToId])
  @@index([leadId])
  @@map("tasks")
}

// ─────────────────────────────────────────
// CLIENTS
// ─────────────────────────────────────────

model Client {
  id               String       @id @default(cuid())
  companyName      String
  contactName      String
  email            String       @unique
  phone            String
  industry         String?
  products         String[]
  orderValue       Float        @default(0)
  contractDuration String?
  startDate        DateTime?
  renewalDate      DateTime?
  status           ClientStatus @default(active)
  linkedLeadId     String?
  accountManagerId String?
  accountManager   User?        @relation("AccountManager", fields: [accountManagerId], references: [id])
  invoices         Invoice[]
  interactions     Interaction[]
  tasks            Task[]
  attachments      Attachment[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  @@index([companyName])
  @@index([email])
  @@index([status])
  @@map("clients")
}

// ─────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount        Float
  gst           Float         @default(0)
  total         Float
  status        InvoiceStatus @default(unpaid)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  paidDate      DateTime?
  paidAmount    Float?
  pdfUrl        String?
  attachments   Attachment[]
  items         InvoiceItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  amount      Float
  createdAt   DateTime @default(now())

  @@map("invoice_items")
}

// ─────────────────────────────────────────
// ATTACHMENTS
// ─────────────────────────────────────────

model Attachment {
  id           String   @id @default(cuid())
  leadId       String?
  lead         Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceId    String?
  invoice      Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  fileName     String
  mimeType     String
  fileSize     Int
  fileData     Bytes
  createdAt    DateTime @default(now())

  @@index([leadId])
  @@index([invoiceId])
  @@map("attachments")
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  type      NotificationType @default(info)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@map("notifications")
}
